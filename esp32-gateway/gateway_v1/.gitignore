# PlatformIO build output and local library cache
.pio/

# VS Code — machine-specific files (keep extensions.json)
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Claude workspace files
.claude/
.claude_cache/

# Codex workspace files
.codex/
.codex_cache/

# CMake files auto-generated by PlatformIO (not needed for Arduino builds)
CMakeLists.txt
src/CMakeLists.txt

# VS Code workspace file (personal, not project-specific)
*.code-workspace

# ESP-IDF auto-generated SDK configuration files
sdkconfig.*
